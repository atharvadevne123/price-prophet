# Application
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///./price_prophet.db
# For production with PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/price_prophet

# Model storage
MODEL_PATH=model.joblib
METRICS_PATH=metrics.json
REFERENCE_STATS_PATH=reference_stats.json
FAISS_INDEX_PATH=faiss_index.pkl

# API
API_HOST=0.0.0.0
API_PORT=8000

# Drift thresholds
DRIFT_P_VALUE_THRESHOLD=0.05
DRIFT_RATE_RETRAIN_THRESHOLD=0.30

# Airflow (optional)
AIRFLOW_PRICE_PROPHET_API=http://price-prophet-api:8000
